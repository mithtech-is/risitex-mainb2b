# RISITEX local infrastructure environment variables.
# Copy this file to `.env` (gitignored) and adjust values for your local setup.
# These are the credentials docker-compose injects into the containers on first boot.
# Apps (backend, storefront) have their own .env files for their own config.

# === PostgreSQL ===
# Container creates this DB + user + password on FIRST boot only.
# Changing these after first boot has no effect — drop the volume to re-init.
POSTGRES_DB=risitex
POSTGRES_USER=risitex
POSTGRES_PASSWORD=risitex_dev_password_CHANGE_ME

# Host port to expose Postgres on. Change to 5433 if 5432 is already taken by a local Postgres.
POSTGRES_PORT=5432

# === Redis ===
# Host port to expose Redis on.
# Heads-up (Windows): 6379 often falls inside winnat's reserved port range
# (run `netsh interface ipv4 show excludedportrange protocol=tcp` to check).
# If `docker compose up` errors with "access permissions" for 6379,
# override to 16379 in your local .env. Linux/Mac developers can leave it at 6379.
REDIS_PORT=6379
