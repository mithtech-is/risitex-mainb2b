# RISITEX pnpm config
#
# Medusa 2.x admin UI is bundled by Vite at runtime inside apps/backend. Vite resolves
# imports from `apps/backend/node_modules` only. With pnpm's strict isolation, transitive
# admin deps (@medusajs/admin-shared, @medusajs/ui, @medusajs/icons, react, etc.) live
# under their parent packages' nested folders and Vite can't see them.
#
# `shamefully-hoist=true` hoists ALL transitive deps to top-level node_modules (npm-style),
# letting Vite resolve them. This is what `create-medusa-app` writes by default; we
# scaffolded manually and missed it.
#
# Trade-off: phantom-dep risk (code can `import` a transitive package without declaring it).
# We mitigate by keeping a small, audited dependency list per workspace.
shamefully-hoist=true

# Make pnpm a little more forgiving of peer-dep version mismatches Medusa won't fix soon
# (e.g. @medusajs/admin-vite-plugin's internal picomatch peer warning).
strict-peer-dependencies=false
