# Copy to .env.local and fill in for backend integration.
# When unset the storefront falls back to bundled product fixtures.

NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000
# Issue from Medusa admin under Settings → Publishable API Keys.
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=

# WhatsApp business number, digits + country code, no plus (e.g. 919876543210)
NEXT_PUBLIC_WHATSAPP_NUMBER=
