{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "declaration": false,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "sourceMap": true,
    "outDir": ".medusa/server",
    "rootDir": ".",
    "strict": false,
    "esModuleInterop": true,
    "lib": ["esnext", "dom"],
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "baseUrl": "."
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["node_modules", ".medusa", "dist"]
}
