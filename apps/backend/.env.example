# RISITEX backend environment variables.
# Copy to .env and fill in your values.

# ── Datastores ───────────────────────────────────────────────────────
# Postgres 16 + Redis 7. The repo expects them at these defaults; if
# you are running the shared D:\risitex\ Docker compose, both are
# already exposed at the host ports below.
DATABASE_URL=postgresql://risitex:risitex_dev_password_CHANGE_ME@localhost:5435/risitex_v2
REDIS_URL=redis://localhost:16380

# ── Security ─────────────────────────────────────────────────────────
# All four MUST be set to a strong random per env. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# The backend rejects "supersecret" for JWT_SECRET/COOKIE_SECRET.
JWT_SECRET=
COOKIE_SECRET=
# At-rest encryption for any DB-stored credential (SMTP password,
# Cashfree client_secret, ERPNext api_secret, etc.). One key for the
# whole system. ≥16 chars. Rotating invalidates every encrypted row —
# re-enter each via the admin UI after rotation.
AT_REST_ENCRYPTION_KEY=
# Phone-OTP server-side pepper. Server-wide secret in sha256(pepper ||
# salt || otp) so even an exfiltrated otp_request table can't be
# brute-forced offline. Rotating invalidates only in-flight (unused)
# OTPs. Falls back to JWT_SECRET if unset.
OTP_PEPPER=

# ── CORS ─────────────────────────────────────────────────────────────
# The storefront runs on :3000 by default (Next.js dev server). It
# MUST appear in STORE_CORS and AUTH_CORS or the browser will block
# every /store/* and /auth/customer/* POST as a CORS preflight
# failure ("Failed to fetch" in the storefront UI). Comma-separated
# list; trim spaces, do not include trailing slashes.
STORE_CORS=http://localhost:3000,http://localhost:3001,http://localhost:8000
ADMIN_CORS=http://localhost:3000,http://localhost:3001,http://localhost:7001,http://localhost:9000
AUTH_CORS=http://localhost:3000,http://localhost:3001,http://localhost:7001,http://localhost:9000

# ── Backend public URL ──────────────────────────────────────────────
MEDUSA_BACKEND_URL=http://localhost:9000

# ── Storefront public URL ───────────────────────────────────────────
# Where the storefront lives. Used to build the referral share link
# (/auth/sign-up?ref=<code>) and any other backend-emitted URLs the
# customer is meant to click. For prod set to your branded domain,
# e.g. https://risitex.com.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Razorpay (Phase 5+ — primary payment provider per FR-4.03) ──────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── Cashfree (Phase 5+ — wallet topup path only; never used for
#    payouts in RISITEX) ──────────────────────────────────────────────
# Dashboard → Developers → API Keys → Production tab.
# "App ID"     → CASHFREE_CLIENT_ID
# "Secret Key" → CASHFREE_CLIENT_SECRET
CASHFREE_ENV=sandbox
CASHFREE_CLIENT_ID=
CASHFREE_CLIENT_SECRET=
# Webhook signing secret (Dashboard → Developers → Webhooks).
CASHFREE_WEBHOOK_SECRET=

# ── ERPNext / Frappe (Phase 8 — sales order sync, inventory poll,
#    delivery note, commission append per FR-5.01 + FR-8.05 + FR-9.x
#    + FR-10.01) ──────────────────────────────────────────────────────
# ERPNEXT_URL = base URL of your Frappe instance, e.g.
# https://erp.risitex.in (no trailing slash).
ERPNEXT_URL=
ERPNEXT_API_KEY=
ERPNEXT_API_SECRET=
ERPNEXT_WEBHOOK_SECRET=

# ── Porter (Phase 9 — local last-mile per FR-5.02 + FR-10.02) ───────
PORTER_API_KEY=

# ── Jira (Phase 9 — production ticketing for backorders per FR-5.03) ─
JIRA_BASE_URL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=

# ── Analytics (optional) ─────────────────────────────────────────────
# POSTHOG_EVENTS_API_KEY=
# POSTHOG_HOST=https://us.i.posthog.com

# ── Communication providers (admin-UI-authoritative — no env vars) ──
# SMTP for email, MSG91 auth_key for SMS, Polygin token for WhatsApp:
# entered through the admin UI at /app/communication and stored
# encrypted-at-rest using AT_REST_ENCRYPTION_KEY above. There are
# intentionally NO env vars for these — the admin UI is authoritative
# so credential rotation doesn't require a deploy.
#
# ADMIN_NOTIFICATION_EMAIL — fallback recipient for event maps with
# to_resolver=admin_email when no override is set in the admin UI.
ADMIN_NOTIFICATION_EMAIL=
